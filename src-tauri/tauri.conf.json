{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "transcriber",
  "version": "0.1.0",
  "identifier": "com.medrenova.transcriber",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "transcriber",
        "width": 1080,
        "height": 482,
        "minWidth": 570,
        "minHeight": 350,
        "center": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
